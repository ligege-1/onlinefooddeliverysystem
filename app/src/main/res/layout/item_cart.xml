<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/iv_cart_food"
        android:layout_width="96dp"
        android:layout_height="72dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cart_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_cart_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_cart_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/danger"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_cart_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_minus"
                android:contentDescription="@null"
                android:padding="6dp"
                android:scaleType="center"
                android:src="@drawable/ic_minus_center" />

            <TextView
                android:id="@+id/tv_cart_count"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btn_cart_add"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_yellow"
                android:contentDescription="@null"
                android:padding="6dp"
                android:scaleType="center"
                android:src="@drawable/ic_plus_center" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
